rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validChapter(chapterId) {
      return chapterId.matches('^local-naruto-([1-9]|[1-9][0-9]|[1-6][0-9][0-9]|700)$')
        || chapterId.matches('^local-one-piece-([1-9]|[1-9][0-9]|[1-9][0-9][0-9]|10[0-9][0-9]|11[0-6][0-9]|117[0-6])$')
        || chapterId.matches('^local-gachiakuta-([1-9]|[1-9][0-9]|1[0-5][0-9]|16[0-6])$')
        || chapterId.matches('^local-alien-headbutt-[1-5]$')
        || chapterId.matches('^local-chainsaw-man-([1-9]|[1-9][0-9]|1[0-9][0-9]|2[0-2][0-9]|23[0-2])$')
        || chapterId.matches('^local-jujutsu-kaisen-([1-9]|[1-9][0-9]|1[0-9][0-9]|2[0-6][0-9]|27[0-2])$')
        || chapterId.matches('^local-fairy-tail-([1-9]|[1-9][0-9]|[1-4][0-9][0-9]|5[0-3][0-9]|54[0-9])$')
        || chapterId.matches('^local-berserk-([1-9]|[1-9][0-9]|[1-2][0-9][0-9]|3[0-7][0-9]|38[0-3])$')
        || chapterId.matches('^local-hajime-no-ippo-([1-9]|[1-9][0-9]|[1-9][0-9][0-9]|1[0-4][0-9][0-9]|150[0-9]|1510)$');
    }

    function validShopAvatar(avatarId) {
      return avatarId in [
        'shop-yuji-itadori',
      ];
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'displayName',
          'email',
          'login',
          'avatarId',
          'theme',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /readChapters/{readId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && readId == request.auth.uid + '_' + request.resource.data.chapterId
        && validChapter(request.resource.data.chapterId)
        && request.resource.data.keys().hasOnly([
          'userId',
          'chapterId',
          'readAt',
          'createdAt'
        ]);
      allow update: if false;
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /dailyQuests/{questId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && questId == request.auth.uid + '_' + request.resource.data.dateKey
        && request.resource.data.chapterIds is list
        && request.resource.data.chapterIds.size() <= 3
        && request.resource.data.keys().hasOnly([
          'userId',
          'dateKey',
          'chapterIds',
          'createdAt'
        ]);
      allow delete: if false;
    }

    match /dailyClaims/{claimId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && claimId == request.auth.uid + '_' + request.resource.data.dateKey + '_' + request.resource.data.chapterId
        && validChapter(request.resource.data.chapterId)
        && request.resource.data.points == 1
        && request.resource.data.keys().hasOnly([
          'userId',
          'dateKey',
          'chapterId',
          'points',
          'createdAt'
        ]);
      allow update, delete: if false;
    }

    match /avatarPurchases/{purchaseId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && purchaseId == request.auth.uid + '_' + request.resource.data.avatarId
        && validShopAvatar(request.resource.data.avatarId)
        && request.resource.data.cost == 100
        && request.resource.data.keys().hasOnly([
          'userId',
          'avatarId',
          'cost',
          'createdAt'
        ]);
      allow update, delete: if false;
    }
  }
}
