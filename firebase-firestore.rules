rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validChapter(chapterId) {
      return chapterId in [
        'local-gachiakuta-1',
        'local-gachiakuta-2',
        'local-alien-headbutt-1',
        'local-naruto-1',
        'local-one-piece-1'
        'local-one-piece-2'
      ];
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'displayName',
          'email',
          'login',
          'avatarId',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /readChapters/{readId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && readId == request.auth.uid + '_' + request.resource.data.chapterId
        && validChapter(request.resource.data.chapterId)
        && request.resource.data.keys().hasOnly([
          'userId',
          'chapterId',
          'readAt',
          'createdAt'
        ]);
      allow update, delete: if false;
    }
  }
}
