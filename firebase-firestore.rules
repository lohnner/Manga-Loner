rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validChapter(chapterId) {
      return chapterId in [
        'local-gachiakuta-1',
        'local-gachiakuta-2',
        'local-alien-headbutt-1',
        'local-naruto-1',
        'local-naruto-2',
        'local-jujutsu-kaisen-1',
        'local-one-piece-1',
        'local-one-piece-2',
        'local-one-piece-3',
        'local-chainsaw-man-1',
        'local-chainsaw-man-2',
      ];
    }

    function validShopAvatar(avatarId) {
      return avatarId in [
        'shop-yuji-itadori',
      ];
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'displayName',
          'email',
          'login',
          'avatarId',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /readChapters/{readId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && readId == request.auth.uid + '_' + request.resource.data.chapterId
        && validChapter(request.resource.data.chapterId)
        && request.resource.data.keys().hasOnly([
          'userId',
          'chapterId',
          'readAt',
          'createdAt'
        ]);
      allow update, delete: if false;
    }

    match /dailyQuests/{questId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && questId == request.auth.uid + '_' + request.resource.data.dateKey
        && request.resource.data.chapterIds is list
        && request.resource.data.chapterIds.size() <= 3
        && request.resource.data.keys().hasOnly([
          'userId',
          'dateKey',
          'chapterIds',
          'createdAt'
        ]);
      allow delete: if false;
    }

    match /dailyClaims/{claimId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && claimId == request.auth.uid + '_' + request.resource.data.dateKey + '_' + request.resource.data.chapterId
        && validChapter(request.resource.data.chapterId)
        && request.resource.data.points == 1
        && request.resource.data.keys().hasOnly([
          'userId',
          'dateKey',
          'chapterId',
          'points',
          'createdAt'
        ]);
      allow update, delete: if false;
    }

    match /avatarPurchases/{purchaseId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && purchaseId == request.auth.uid + '_' + request.resource.data.avatarId
        && validShopAvatar(request.resource.data.avatarId)
        && request.resource.data.cost == 100
        && request.resource.data.keys().hasOnly([
          'userId',
          'avatarId',
          'cost',
          'createdAt'
        ]);
      allow update, delete: if false;
    }
  }
}
